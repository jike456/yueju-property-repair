<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.hello.mapper.OwnerMapper">

    <resultMap id="OwnerResultMap" type="com.example.hello.entity.Owner">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="building_no" property="buildingNo"/>
        <result column="unit_no" property="unitNo"/>
        <result column="room_no" property="roomNo"/>
        <result column="area" property="area"/>
        <result column="move_in_date" property="moveInDate"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.hello.entity.Owner" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO owner
        (user_id, building_no, unit_no, room_no, area, move_in_date, create_time)
        VALUES
        (#{userId}, #{buildingNo}, #{unitNo}, #{roomNo}, #{area}, #{moveInDate}, #{createTime})
    </insert>

    <select id="selectByUserId" parameterType="long" resultMap="OwnerResultMap">
        SELECT id, user_id, building_no, unit_no, room_no, area, move_in_date, create_time
        FROM owner
        WHERE user_id = #{userId}
    </select>

    <select id="selectById" parameterType="long" resultMap="OwnerResultMap">
        SELECT id, user_id, building_no, unit_no, room_no, area, move_in_date, create_time
        FROM owner
        WHERE id = #{id}
    </select>

    <delete id="deleteByUserId">
        DELETE FROM owner WHERE user_id = #{userId}
    </delete>
</mapper>

